generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("USER") // ADMIN | USER
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  filePointers FilePointer[]
  permissions  Permission[]
  ownedFolders Folder[]      @relation("UserOwnedFolders")
}

model Folder {
  id             String        @id @default(uuid())
  parentFolderId String?
  ownerUserId    String?
  name           String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  ownerUser      User?         @relation("UserOwnedFolders", fields: [ownerUserId], references: [id], onDelete: SetNull)
  parentFolder   Folder?       @relation("FolderHierarchy", fields: [parentFolderId], references: [id], onDelete: Cascade)
  subFolders     Folder[]      @relation("FolderHierarchy")
  filePointers   FilePointer[]
  permissions    Permission[]
}

model PhysicalObject {
  hashSha256 String        @id
  sizeBytes  Int           // Size in bytes
  createdAt  DateTime      @default(now())

  pointers   FilePointer[]
}

model FilePointer {
  id            String         @id @default(uuid())
  folderId      String?
  userId        String
  originalName  String
  fileExtension String
  hashSha256    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  folder         Folder?        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  physicalObject PhysicalObject @relation(fields: [hashSha256], references: [hashSha256], onDelete: Cascade)
}

model Permission {
  id          String   @id @default(uuid())
  userId      String
  folderId    String
  accessLevel String   // NONE | READ | READ_WRITE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([userId, folderId])
}
